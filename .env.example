# Copy this file to .env and fill in the values.

# Base URL of the Laravel API (no trailing slash).
# Use /api/v1 for same-domain deployment (default).
# Change to a full URL when the backend is on a different host.
VITE_API_BASE_URL=/api/v1

# Google reCAPTCHA v3 site key (optional – used by contact/newsletter forms).
VITE_RECAPTCHA_SITE_KEY=

# Google Analytics Measurement ID (optional).
VITE_GA_ID=G-LLVF13CFL1
